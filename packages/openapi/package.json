{
  "name": "@api-introspect/openapi",
  "type": "module",
  "version": "0.14.0",
  "description": "OpenAPI / Swagger spec to introspection. Convert third-party API specs into a unified EndpointInfo list.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/callmewhy/api-introspect.git",
    "directory": "packages/openapi"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.check.json --noEmit && tsdown",
    "dev": "tsdown --watch --no-clean",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@api-introspect/core": "workspace:*"
  }
}
